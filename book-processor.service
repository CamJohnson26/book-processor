[Unit]
Description=Book Processor Service
After=network.target

[Service]
Type=simple
User=USER_PLACEHOLDER
WorkingDirectory=PATH_PLACEHOLDER
Environment=PATH=PATH_PLACEHOLDER/.venv/bin:$PATH
ExecStart=PATH_PLACEHOLDER/.venv/bin/python3 -u PATH_PLACEHOLDER/main.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
